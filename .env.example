# BIW DFMEA-DVP&R AI Assistant - environment configuration
# Copy to .env and fill in what you need. Everything has safe defaults.

# ---- Vector store / retrieval ----
VECTOR_DB_PATH=./data/vector_store
RAG_TOP_K_DFMEA=5
RAG_TOP_K_DVPR=5
RAG_TOP_K_LESSONS=3
RAG_TOP_K_STANDARDS=3
RAG_MIN_SIMILARITY=0.30
# Set to 1 to skip the sentence-transformers model (offline demo / CI)
RAG_FORCE_FALLBACK_EMBEDDER=

# ---- Optional LLM generation layer (leave RAG_LLM_PROVIDER empty to disable) ----
# Provider: anthropic | openai
RAG_LLM_PROVIDER=

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI or OpenAI-compatible gateway (incl. Azure via base URL)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

LLM_MAX_TOKENS=4000
